# Environment variables and secrets
.env
.env.*
!.env.example
**/secrets/**
**/*secret*
**/*token*
# Safe tracked source code. The real API token is stored outside the workspace.
!/scripts/api/save_clash_api_token.ps1
*.pem
*.key
credentials*.json

# Python bytecode and virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# IDE and editor settings
.idea/
.vscode/
*.code-workspace
*.swp
*.swo

# Test, type-checker and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Logs and temporary files
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.cache

# Local databases and journals
*.db
*.db-*
*.sqlite
*.sqlite3
*.sqlite-*
*.duckdb

# Backups and local-only configuration
*.bak
*.backup
*.old
backups/
config.local.*
*.local.json
*.local.yaml
*.local.yml
local/

# Private and service exports (public site/data remains trackable)
private/
internal/
service_exports/
exports/private/
exports/internal/
*.private.csv
*.private.json
*.internal.csv
*.internal.json

# Build artifacts
build/
dist/
*.egg-info/

# Windows and OS files
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

